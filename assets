<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
/>

<title>AI PDF Mobile Reader</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Sentinel-esque serif -->

<link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;500;600&display=swap"
    rel="stylesheet"
>

<style>

:root{

    --bg:#11130f;

    --panel:#1a1c17;

    --border:#35382f;

    --text:#f3f1ea;

    --muted:#a39f8c;

    --accent:#9d9162;

    --accent-dark:#7f744d;

    --accent-light:#c1b27b;
}

*{
    box-sizing:border-box;
}

html,
body{

    margin:0;
    padding:0;

    width:100%;
    max-width:100%;

    overflow-x:hidden;
}

html{

    scroll-behavior:smooth;

    background:var(--bg);
}

body{

    background:var(--bg);

    color:var(--text);

    font-family:'Source Serif 4', Georgia, serif;

    -webkit-font-smoothing:antialiased;

    text-rendering:optimizeLegibility;
}

/* HEADER */

header{

    position:sticky;

    top:0;

    z-index:500;

    width:100%;

    padding:16px;

    background:rgba(17,19,15,0.95);

    backdrop-filter:blur(12px);

    border-bottom:1px solid var(--border);
}

.toolbar{

    display:flex;

    flex-wrap:wrap;

    align-items:center;

    gap:12px;

    width:100%;

    position:relative;
}

input[type="file"]{

    color:var(--muted);

    font-family:inherit;

    max-width:100%;
}

button{

    border:none;

    border-radius:12px;

    padding:12px 18px;

    background:var(--accent);

    color:#161710;

    font-weight:700;

    cursor:pointer;

    font-family:inherit;

    transition:all 0.2s ease;
}

button:hover{

    background:var(--accent-light);
}

#status{

    color:var(--muted);

    font-size:14px;
}

/* PROGRESS */

.progress-wrapper{

    width:100%;

    height:8px;

    background:#272922;

    border-radius:999px;

    overflow:hidden;

    margin-top:14px;
}

.progress-bar{

    width:0%;

    height:100%;

    background:linear-gradient(
        90deg,
        var(--accent-dark),
        var(--accent-light)
    );

    transition:width 0.25s ease;
}

/* MAIN */

main{

    width:100%;

    max-width:none;

    margin:0;

    padding:38px 18px 120px;
}

.article{

    display:flex;

    flex-direction:column;

    gap:90px;

    width:100%;
}

/* TEXT */

.section{

    width:100%;

    line-height:1.82;

    font-size:1rem;

    letter-spacing:0.01em;

    word-wrap:break-word;

    overflow-wrap:break-word;
}

.section h2{

    font-size:0.9rem;

    text-transform:uppercase;

    letter-spacing:3px;

    color:var(--muted);

    margin-bottom:36px;

    font-weight:600;

    font-family:system-ui,sans-serif;
}

.section p{

    margin-bottom:1.8rem;

    max-width:100%;
}

.loading{

    text-align:center;

    padding:90px 20px;

    color:var(--muted);

    font-size:1.05rem;
}

/* FONT BUTTON
   ATTACHED TO HEADER
*/

.floating{

    position:absolute;

    top:0;

    right:0;

    display:none;

    z-index:1000;
}

.fab{

    width:38px;

    height:38px;

    border-radius:999px;

    background:rgba(26,28,23,0.96);

    border:1px solid var(--border);

    color:var(--text);

    font-size:13px;

    font-weight:700;

    cursor:pointer;

    padding:0;

    display:flex;

    align-items:center;

    justify-content:center;

    backdrop-filter:blur(10px);

    -webkit-backdrop-filter:blur(10px);

    transition:background 0.2s ease;
}

.fab:hover{

    background:#252820;
}

/* FONT PANEL */

.font-panel{

    position:absolute;

    top:54px;

    right:0;

    width:170px;

    max-width:calc(100vw - 32px);

    background:rgba(26,28,23,0.98);

    border:1px solid var(--border);

    border-radius:18px;

    padding:14px;

    z-index:2000;

    backdrop-filter:blur(14px);

    display:none;

    box-shadow:0 14px 40px rgba(0,0,0,0.45);
}

.font-panel-title{

    font-size:12px;

    text-transform:uppercase;

    letter-spacing:2px;

    color:var(--muted);

    margin-bottom:14px;

    font-family:system-ui,sans-serif;
}

.font-controls{

    display:flex;

    align-items:center;

    justify-content:space-between;

    gap:10px;
}

.font-btn{

    width:38px;

    height:38px;

    border-radius:12px;

    border:none;

    background:#2b2e25;

    color:var(--text);

    font-size:16px;

    cursor:pointer;

    transition:all 0.2s ease;
}

.font-btn:hover{

    background:#393d31;
}

.font-size-display{

    font-size:14px;

    color:var(--muted);

    min-width:42px;

    text-align:center;

    font-family:system-ui,sans-serif;
}

/* SELECTION */

::selection{

    background:#5b5537;

    color:white;
}

/* SCROLLBAR */

::-webkit-scrollbar{

    width:10px;
}

::-webkit-scrollbar-thumb{

    background:#3c4035;

    border-radius:999px;
}

/* MOBILE */

@media(max-width:700px){

    main{

        padding:28px 14px 120px;
    }

    .section{

        font-size:1rem;

        line-height:1.76;
    }

    .section h2{

        margin-bottom:30px;
    }

    .section p{

        margin-bottom:1.6rem;
    }

}

</style>
</head>

<body>

<header>

    <div class="toolbar">

        <input
            type="file"
            id="pdfFile"
            accept="application/pdf"
        />

        <button id="processBtn">
            Extract PDF
        </button>

        <span id="status">
            Ready
        </span>

        <!-- A+ BUTTON INSIDE HEADER -->

        <div class="floating" id="fontControls">

            <button class="fab" id="fontToggle">
                A+
            </button>

            <!-- FONT PANEL -->

            <div class="font-panel" id="fontPanel">

                <div class="font-panel-title">
                    Font Size
                </div>

                <div class="font-controls">

                    <button class="font-btn" id="fontDown">
                        −
                    </button>

                    <div
                        class="font-size-display"
                        id="fontSizeDisplay">
                        1.00x
                    </div>

                    <button class="font-btn" id="fontUp">
                        +
                    </button>

                </div>

            </div>

        </div>

    </div>

    <div class="progress-wrapper">

        <div
            class="progress-bar"
            id="progressBar">
        </div>

    </div>

</header>

<main>

    <section id="reader" class="article">

        <div class="loading">
            Upload a PDF to begin.
        </div>

    </section>

</main>

<script type="module">

import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.min.mjs';

pdfjsLib.GlobalWorkerOptions.workerSrc =
'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.worker.min.mjs';

const pdfFile =
    document.getElementById('pdfFile');

const processBtn =
    document.getElementById('processBtn');

const reader =
    document.getElementById('reader');

const statusText =
    document.getElementById('status');

const progressBar =
    document.getElementById('progressBar');

const fontControls =
    document.getElementById('fontControls');

const fontToggle =
    document.getElementById('fontToggle');

const fontPanel =
    document.getElementById('fontPanel');

const fontSizeDisplay =
    document.getElementById('fontSizeDisplay');

let currentFontSize = 1.00;

/* PROGRESS */

function setProgress(percent){

    progressBar.style.width =
        percent + '%';
}

/* STATUS */

function setStatus(text){

    statusText.textContent = text;
}

/* FONT */

function updateFont(){

    document
        .querySelectorAll('.section')
        .forEach(section=>{

            section.style.fontSize =
                currentFontSize + 'rem';

        });

    fontSizeDisplay.textContent =
        currentFontSize.toFixed(2) + 'x';
}

/* CLEAN TEXT */

function cleanText(text){

    return text
        .replace(/\s+/g,' ')
        .replace(/([.!?])\s+(?=[A-Z])/g,'$1\n\n')
        .replace(/-\s+/g,'')
        .trim();
}

/* SPLIT INTO PARTS */

function splitSections(text){

    const paragraphs =
        text.split(/\n{2,}/);

    const sections = [];

    let chunk = [];

    let wordCount = 0;

    paragraphs.forEach((paragraph)=>{

        chunk.push(paragraph);

        wordCount +=
            paragraph.split(' ').length;

        if(wordCount >= 1800){

            sections.push(
                chunk.join('\n\n')
            );

            chunk = [];

            wordCount = 0;
        }

    });

    if(chunk.length){

        sections.push(
            chunk.join('\n\n')
        );
    }

    return sections;
}

/* RENDER */

function renderSections(sections){

    reader.innerHTML = '';

    sections.forEach((section,index)=>{

        const wrapper =
            document.createElement('section');

        wrapper.className = 'section';

        const title =
            document.createElement('h2');

        title.textContent =
            `Part ${index + 1}`;

        wrapper.appendChild(title);

        const paragraphs =
            section.split('\n\n');

        paragraphs.forEach(text=>{

            const p =
                document.createElement('p');

            p.textContent = text;

            wrapper.appendChild(p);

        });

        reader.appendChild(wrapper);

    });

}

/* PROCESS PDF */

processBtn.addEventListener(
    'click',
    async ()=>{

    try{

        const file = pdfFile.files[0];

        if(!file){

            alert(
                'Please upload a PDF first.'
            );

            return;
        }

        reader.innerHTML = `
            <div class="loading">
                Processing PDF...
            </div>
        `;

        fontControls.style.display = 'none';

        setProgress(0);

        setStatus('Loading PDF...');

        const buffer =
            await file.arrayBuffer();

        const loadingTask =
            pdfjsLib.getDocument({
                data:buffer
            });

        loadingTask.onProgress =
            (progress)=>{

            if(progress.total){

                const percent =
                    (
                        progress.loaded /
                        progress.total
                    ) * 100;

                setProgress(percent * 0.25);

                setStatus(
                    'Downloading PDF ' +
                    Math.round(percent) +
                    '%'
                );
            }

        };

        const pdf =
            await loadingTask.promise;

        let text = '';

        for(
            let pageNumber = 1;
            pageNumber <= pdf.numPages;
            pageNumber++
        ){

            setStatus(
                `Reading page ${pageNumber} of ${pdf.numPages}`
            );

            const page =
                await pdf.getPage(pageNumber);

            const content =
                await page.getTextContent();

            const pageText =
                content.items
                    .map(item=>item.str)
                    .join(' ');

            text += '\n\n' + pageText;

            const pageProgress =
                (
                    pageNumber /
                    pdf.numPages
                ) * 75;

            setProgress(
                25 + pageProgress
            );
        }

        setStatus('Cleaning text...');

        const cleanedText =
            cleanText(text);

        setStatus('Formatting parts...');

        const sections =
            splitSections(cleanedText);

        renderSections(sections);

        updateFont();

        setProgress(100);

        setStatus('Complete');

        fontControls.style.display =
            'block';

    }catch(error){

        console.error(error);

        reader.innerHTML = `
            <div class="loading">
                Error processing PDF.
            </div>
        `;

        setProgress(0);

        setStatus('Error');
    }

});

/* TOGGLE PANEL */

fontToggle.addEventListener(
    'click',
    ()=>{

    if(
        fontPanel.style.display ===
        'block'
    ){

        fontPanel.style.display =
            'none';

    }else{

        fontPanel.style.display =
            'block';
    }

});

/* INCREASE FONT */

document
    .getElementById('fontUp')
    .addEventListener('click',()=>{

        currentFontSize += 0.08;

        updateFont();

});

/* DECREASE FONT */

document
    .getElementById('fontDown')
    .addEventListener('click',()=>{

        currentFontSize =
            Math.max(
                0.75,
                currentFontSize - 0.08
            );

        updateFont();

});

/* CLOSE PANEL */

document.addEventListener(
    'click',
    (event)=>{

    const clickedInsidePanel =
        fontPanel.contains(
            event.target
        );

    const clickedToggle =
        fontToggle.contains(
            event.target
        );

    if(
        !clickedInsidePanel &&
        !clickedToggle
    ){

        fontPanel.style.display =
            'none';
    }

});

</script>

</body>
</html>
